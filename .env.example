# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a ".env"  (sin el ".example")
#   2. Reemplaza los valores de ejemplo con tus credenciales reales
#   3. NUNCA subas el archivo .env a GitHub (ya está en .gitignore)
#
# CÓMO OBTENER TUS CREDENCIALES:
#   - GITHUB_TOKEN: Ve a https://github.com/settings/tokens
#     → "Generate new token (classic)" → activa el scope "models:read"
#     → copia el token generado
#   - GITHUB_BASE_URL: Esta URL es fija para GitHub Models, no cambia.
#
# ─────────────────────────────────────────────────────────────────────────────

# Token de acceso personal de GitHub (necesario para usar GitHub Models / GPT-4o)
GITHUB_TOKEN=ghp_TU_TOKEN_AQUI

# URL base de la API de GitHub Models (no modificar)
GITHUB_BASE_URL=https://models.inference.ai.azure.com
